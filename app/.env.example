# WorkProof — Expo build-time env vars
#
# Copy to `.env` (which is gitignored) and fill in real values. Expo's
# babel-preset-expo inlines EXPO_PUBLIC_* into the bundle at build time,
# which means the values here are extractable from the shipped APK.
# Do NOT put actual secrets (bearer tokens, private keys with mainnet
# balance, etc.) into any EXPO_PUBLIC_* variable — none of the app's
# runtime secrets should live here.
#
# Notes:
# - The CipherStack service token lives ONLY in Vercel's server env
#   (CIPHERSTACK_TOKEN, no EXPO_PUBLIC_ prefix). See task #31.
# - The anchor signing key is generated per-install and persisted in
#   expo-secure-store (Keychain / EncryptedSharedPreferences); no shared
#   wallet key is bundled. See services/identity.ts and task #33.

# Base URL of the Vercel deployment hosting /api/vend. Native builds
# (Expo Go / APK) route Gemini vend calls through this URL so the
# CipherStack service token stays server-side. Web builds use
# same-origin `/api/vend` and ignore this value. Default in code:
# https://workproof-demo.vercel.app.
EXPO_PUBLIC_API_VEND_BASE_URL=https://workproof-demo.vercel.app

# Deployed WorkProofAnchor contract address on Polygon Amoy (testnet).
# When unset, anchor calls fall back to `queued:` synthetic tx ids and
# flushQueue is a no-op (task #29 tracks the contract deployment).
EXPO_PUBLIC_ANCHOR_ADDRESS=0x0000000000000000000000000000000000000000
