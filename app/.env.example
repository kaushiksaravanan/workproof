# WorkProof — Expo build-time env vars
#
# Copy to `.env` (which is gitignored) and fill in real values. Expo's
# babel-preset-expo inlines EXPO_PUBLIC_* into the bundle at build time.

# CipherStack service token — vends the Gemini key used by the on-device
# extractor. Get one from https://cipherstack.kaushik.cv (or run your own).
#
# NATIVE builds (Expo Go / APK) bundle this token and hit CipherStack directly.
# WEB builds route through /api/vend on Vercel instead — that path reads
# `CIPHERSTACK_TOKEN` (no EXPO_PUBLIC_ prefix) from Vercel's env, so the token
# never lands in the browser bundle. If you're only deploying to web, you can
# leave this unset locally and rely on the serverless proxy in production.
EXPO_PUBLIC_CIPHERSTACK_TOKEN=csk_your_service_token_here

# Hackathon demo signing key — used to sign the proof bundle. Any hex
# private key works for the demo; do NOT reuse a real wallet key.
EXPO_PUBLIC_HACKATHON_KEY=0xabcdef0123456789...

# Deployed anchor contract address on Polygon Amoy (testnet).
EXPO_PUBLIC_ANCHOR_ADDRESS=0x0000000000000000000000000000000000000000
