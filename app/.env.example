# WorkProof — Expo build-time env vars
#
# Copy to `.env` (which is gitignored) and fill in real values. Expo's
# babel-preset-expo inlines EXPO_PUBLIC_* into the bundle at build time,
# which means the values here are extractable from the shipped APK.
# Do NOT put actual secrets (bearer tokens, private keys with mainnet
# balance, etc.) into any EXPO_PUBLIC_* variable — see workproof task #31
# and #33 for the tracking issues on moving signing/vending server-side.

# Base URL of the Vercel deployment hosting /api/vend. Native builds
# (Expo Go / APK) route Gemini vend calls through this URL so the
# CipherStack service token stays server-side (it lives only in the
# Vercel serverless env). Web builds use same-origin `/api/vend` and
# ignore this value. Default in code: https://workproof-demo.vercel.app.
# Override this to point at a local Vercel dev server, a preview deploy,
# or your own fork.
EXPO_PUBLIC_API_VEND_BASE_URL=https://workproof-demo.vercel.app

# Hackathon demo signing key — used to sign the proof anchor transaction.
# Any hex private key works for the demo; do NOT reuse a real wallet key.
# Reminder: EXPO_PUBLIC_* is extractable from the APK. This key is
# demo-mode only. See task #31 for the plan to remove this and adopt
# a per-install / server-side signing scheme.
EXPO_PUBLIC_HACKATHON_KEY=0xabcdef0123456789...

# Deployed anchor contract address on Polygon Amoy (testnet).
EXPO_PUBLIC_ANCHOR_ADDRESS=0x0000000000000000000000000000000000000000
