{
  "expo": {
    "name": "WorkProof",
    "slug": "workproof",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.workproof.app"
    },
    "android": {
      "package": "com.workproof.app"
    },
    "web": {
      "bundler": "metro",
      "name": "WorkProof",
      "shortName": "WorkProof",
      "description": "Field-ready proof-of-work capture — photo + voice + GPS to signed PDF, anchored to Polygon Amoy.",
      "themeColor": "#7DA1FF",
      "backgroundColor": "#E3E3E3",
      "lang": "en",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/",
      "meta": {
        "apple-mobile-web-app-title": "WorkProof",
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "default"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WorkProof to take photos of your work.",
          "microphonePermission": "Allow WorkProof to record voice notes.",
          "recordAudioAndroid": true
        }
      ],
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Allow WorkProof to access your microphone for voice reports."
        }
      ]
    ]
  }
}
